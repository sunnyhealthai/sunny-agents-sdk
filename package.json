{
  "name": "@sunnyhealthai/agents-sdk",
  "version": "0.0.62",
  "description": "Embed the Sunny Agents chat experience inside any app.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "https://github.com/sunnyhealthai/sunny-agents-sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "packageManager": "pnpm@10.25.0",
  "keywords": [
    "sunny",
    "chat",
    "agents",
    "sdk"
  ],
  "author": "Sunny Health AI",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "libphonenumber-js": "^1.13.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
